generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String  @id @default(uuid())
  name             String
  email            String  @unique
  password         String
  hashedRt         String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  apiKeys ApiKey[]
}

model ApiKey {
  id      String @id @default(uuid())
  name    String
  keyHash String @unique
  prefix  String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  lastUsedAt DateTime?
  expiresAt  DateTime?
  isRevoked  Boolean   @default(false)
  createdAt  DateTime  @default(now()) 
  updatedAt  DateTime  @default(now()) @updatedAt
}

model Product {
  id        String   @id @default(uuid())
  sku       String   @unique
  name      String
  category  String
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int      @default(0)
  unit      String   @default("pieza")
  minStock  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id            String   @id @default(uuid())
  date          DateTime @default(now())
  customer      String?
  items         Json
  subtotal      Decimal  @db.Decimal(10, 2)
  tax           Decimal  @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(10, 2)
  status        String   @default("paid")
  paymentMethod String   @default("cash")
  createdAt     DateTime @default(now())
}

model Purchase {
  id           String   @id @default(uuid())
  date         DateTime @default(now())
  supplier     String
  items        Json
  subtotal     Decimal  @db.Decimal(10, 2)
  tax          Decimal  @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(10, 2)
  status       String   @default("pending")
  expectedDate DateTime?
  createdAt    DateTime @default(now())
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  segment   String   @default("regular")
  address   String?
  birthDate DateTime?
  notes     String?
  createdAt DateTime @default(now())
  visits    Visit[]
}

model Visit {
  id            String   @id @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  date          DateTime
  time          String
  type          String   @default("scheduled")
  effectiveness String   @default("pending")
  purpose       String?
  notes         String?
  duration      Int?
  nextVisit     DateTime?
  createdAt     DateTime @default(now())
}

// Manufacturing
model ProcessStep {
  id          String @id @default(uuid())
  processId   String @unique
  processName String
  description String
  order       Int
}

model CompositeProduct {
  id        String  @id @default(uuid())
  name      String
  sku       String  @unique
  category  String
  unit      String  @default("unid")
  salePrice Decimal @db.Decimal(10, 2)
  emoji     String  @default("📦")
  bom       Json    // [{ ingredientId, ingredientName, quantity, unit, unitCost }]
  routing   Json    // [{ processStepId, processName, costPerUnit, timeMinutes }]
}

model ProductionOrder {
  id                   String   @id @default(uuid())
  compositeProductId   String
  compositeProductName String
  quantityPlanned      Int
  quantityProduced     Int      @default(0)
  status               String   @default("planned")
  scheduledDate        DateTime
  completedDate        DateTime?
  notes                String?
  createdAt            DateTime @default(now())
}

// Accounting
model Account {
  id      String @id @default(uuid())
  code    String @unique
  name    String
  type    String // asset | liability | equity | revenue | expense
  balance Decimal @db.Decimal(12, 2) @default(0)
}

model JournalEntry {
  id          String   @id @default(uuid())
  date        DateTime
  description String
  reference   String
  status      String   @default("posted")
  lines       Json     // [{ accountId, accountName, debit, credit }]
  createdAt   DateTime @default(now())
}

// Payroll
model Employee {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  phone           String
  position        String
  department      String
  salary          Decimal  @db.Decimal(10, 2)
  hireDate        DateTime
  status          String   @default("active")
  avatar          String   @default("👤")
  address         String?
  birthDate       DateTime?
  bloodType       String?
  emergencyContact String?
  emergencyPhone  String?
  createdAt       DateTime @default(now())
}

model AttendanceRecord {
  id           String   @id @default(uuid())
  employeeId   String
  employeeName String
  date         DateTime
  clockIn      String?
  clockOut     String?
  hoursWorked  Decimal  @db.Decimal(4, 2) @default(0)
  status       String   @default("present")
}

model LeaveRequest {
  id           String   @id @default(uuid())
  employeeId   String
  employeeName String
  type         String   @default("personal")
  startDate    DateTime
  endDate      DateTime
  days         Int
  reason       String
  status       String   @default("pending")
  approvedBy   String?
  createdAt    DateTime @default(now())
}

model PayrollRecord {
  id           String   @id @default(uuid())
  employeeId   String
  employeeName String
  period       String
  baseSalary   Decimal  @db.Decimal(10, 2)
  bonuses      Decimal  @db.Decimal(10, 2) @default(0)
  deductions   Decimal  @db.Decimal(10, 2) @default(0)
  tax          Decimal  @db.Decimal(10, 2) @default(0)
  netPay       Decimal  @db.Decimal(10, 2)
  status       String   @default("pending")
  paidDate     DateTime?
  createdAt    DateTime @default(now())
}
